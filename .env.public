# Public environment variable template
# Copy this file to .env and fill in your actual API keys
# Never commit .env to version control

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# Meta (Llama via third-party providers, e.g. Together AI)
TOGETHER_API_KEY=

# Groq
GROQ_API_KEY=

# Hugging Face
HUGGINGFACE_API_KEY=

# Stability AI (image/video generation)
STABILITY_API_KEY=

# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=

# Suno (music generation)
SUNO_API_KEY=

# Udio (music generation)
UDIO_API_KEY=

# Runway (video generation)
RUNWAY_API_KEY=

# Pika (video generation)
PIKA_API_KEY=

# Kling AI (video generation)
KLING_API_KEY=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
